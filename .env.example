# Environment configuration for the Baseball Scoring app.
#
# Two env files are used (both gitignored):
#   .env.development  — dev Supabase project, loaded by `npm run dev`
#   .env.production   — prod Supabase project, loaded by `npm run build`
#
# Copy this file to whichever env file you need and fill in the values.

# Supabase project URL and anon key (Supabase → Settings → API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# App version shown in the UI (keep "0.0.0-dev" in .env.development)
VITE_APP_VERSION=1.0.0

# Supabase project reference ID (Supabase → Settings → General → Reference ID)
# Used by `npm run deploy-functions:dev` / `deploy-functions:prod`
SUPABASE_PROJECT_REF=your-project-ref

# PostgreSQL connection string for `npm run migrate:dev` / `migrate:prod`
# (Supabase → Settings → Database → Connection string → URI)
DATABASE_URL=postgresql://postgres.[ref]:[password]@[host]:5432/postgres

# ── Local development (optional) ──────────────────────────────────────────────
# For a fully offline local stack, copy the lines below into a new .env.localdev
# file (never committed). Run `npm run supabase:start` — it prints the anon key.
# Then start the dev server with `npm run dev:local` (not `npm run dev`).
#
# VITE_SUPABASE_URL=http://127.0.0.1:54321
# VITE_SUPABASE_ANON_KEY=<printed by `supabase start`>
# VITE_APP_VERSION=0.0.0-local
# SUPABASE_PROJECT_REF=local
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
